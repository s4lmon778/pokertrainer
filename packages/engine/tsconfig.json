{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "../..",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "ignoreDeprecations": "5.0"
  },
  "include": [
    "../../src/engine/**/*.ts",
    "../../src/types/**/*.ts",
    "../../src/utils/botEngine.ts",
    "../../src/utils/configExport.ts",
    "../../src/utils/deck.ts",
    "../../src/utils/equity.ts",
    "../../src/utils/handEvaluator.ts",
    "../../src/utils/sidePot.ts"
  ],
  "exclude": ["node_modules", "dist", "src/**/*.test.ts", "src/**/*.test.tsx", "**/*.js", "**/*.d.ts"]
}
