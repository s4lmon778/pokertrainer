{
  "name": "@pokertrainer/engine",
  "version": "1.1.1",
  "description": "PokerBot core poker engine — GTO solver, Training Bot, hand evaluator",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/index.js",
    "dist/index.d.ts",
    "dist/index.js.map",
    "dist/index.d.ts.map"
  ],
  "scripts": {
    "build": "tsc && npm run clean-artifacts",
    "clean-artifacts": "rm -rf dist/src dist/packages 2>/dev/null; exit 0",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "keywords": ["poker", "gto", "training", "bot", "solver"],
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
