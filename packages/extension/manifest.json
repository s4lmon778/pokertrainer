{
  "manifest_version": 3,
  "name": "PokerBot Bridge",
  "version": "1.0.0",
  "description": "Connects browser poker games to PokerBot desktop app for automated play.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "*://*.ggpoker.com/*",
    "*://*.ggpoker.net/*",
    "*://*.ignitioncasino.eu/*",
    "*://*.bovada.lv/*",
    "*://*.coinpoker.com/*",
    "*://*.americascardroom.eu/*",
    "*://*.pokerstars.com/*",
    "*://*.pokerstars.net/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.ggpoker.com/*",
        "*://*.ggpoker.net/*",
        "*://*.ignitioncasino.eu/*",
        "*://*.bovada.lv/*",
        "*://*.coinpoker.com/*",
        "*://*.americascardroom.eu/*",
        "*://*.pokerstars.com/*",
        "*://*.pokerstars.net/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PokerBot Bridge"
  }
}
